# OS files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# Editor files
.vscode/
.idea/
*.swp
*.swo
*~
.cursor/
.claude/
.kilocodemodes

# Stray screenshots at theme root (not theme assets)
/Screenshot_*.jpg
/Screenshot_*.png

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Dependencies
/node_modules/
/vendor/

# WordPress core (not needed - we're only deploying theme files)
wp-config.php
wp-content/uploads/
wp-content/upgrade/
wp-content/backup-db/
wp-content/advanced-cache.php
wp-content/wp-cache-config.php

# Development/backup files
*.bak
*.backup
*.tmp
*.temp

# Documentation and history (moved to not needed/)
.history/
not needed/

# Environment files
.env
.env.local
.env.*.local

# Build files at repository root only (nested apps may have their own dist)
/dist/
/build/

# Next.js / tooling at repository root only (nested DEMO/ is a Vite app we track)
/package.json
/package-lock.json
/yarn.lock
/next.config.*
/tsconfig.json
/src/
/.next/
/postcss.config.*
/tailwind.config.*

# Vite UI demos build output
/DEMO/dist/

# Composer (no dependencies, lock file auto-generated by Hostinger)
composer.lock

# Theme-vendored JS (e.g. balloons-js ESM) lives under assets/js/vendor/

# Generated CSS bundles (optional local build — not loaded by WordPress)
assets/css/bundles/*.css
