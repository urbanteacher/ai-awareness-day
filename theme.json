{
  "$schema": "https://schemas.wp.org/wp/6.6/theme.json",
  "version": 3,
  "settings": {
    "appearanceTools": true,
    "layout": {
      "contentSize": "720px",
      "wideSize": "1200px"
    },
    "color": {
      "link": true,
      "palette": [
        { "slug": "white", "color": "#ffffff", "name": "White" },
        { "slug": "black", "color": "#000000", "name": "Black" },
        { "slug": "gray-100", "color": "#f5f5f5", "name": "Gray 100" },
        { "slug": "gray-500", "color": "#737373", "name": "Gray 500" },
        { "slug": "gray-900", "color": "#171717", "name": "Gray 900" },
        { "slug": "green-600", "color": "#171717", "name": "Accent" }
      ]
    },
    "typography": {
      "defaultFontSizes": false,
      "lineHeight": true,
      "fontFamilies": [
        {
          "slug": "display",
          "name": "Intel Clear",
          "fontFamily": "'Intel Clear', sans-serif",
          "fontFace": [
            {
              "fontFamily": "Intel Clear",
              "fontWeight": "400 700",
              "fontStyle": "normal",
              "fontDisplay": "swap",
              "src": [ "https://fonts.cdnfonts.com/s/18413/IntelClear-Light.woff" ]
            }
          ]
        },
        {
          "slug": "body",
          "name": "DM Sans",
          "fontFamily": "'DM Sans', sans-serif",
          "fontFace": [
            {
              "fontFamily": "DM Sans",
              "fontWeight": "400 700",
              "fontStyle": "normal",
              "fontDisplay": "swap",
              "src": [ "https://fonts.gstatic.com/s/dmsans/v11/rP2Fp2K8z96vMv6_vg7m.woff2" ]
            }
          ]
        }
      ],
      "fontSizes": [
        { "slug": "small", "size": "0.875rem", "name": "Small" },
        { "slug": "medium", "size": "1rem", "name": "Medium" },
        { "slug": "large", "size": "1.25rem", "name": "Large" },
        { "slug": "x-large", "size": "1.5rem", "name": "Extra large" }
      ]
    },
    "spacing": {
      "units": [ "px", "em", "rem", "%", "vw", "vh" ]
    },
    "border": {
      "color": true,
      "radius": true,
      "style": true,
      "width": true
    }
  },
  "styles": {
    "color": {
      "text": "var(--wp--preset--color--gray-900, #171717)"
    },
    "typography": {
      "fontFamily": "var(--wp--preset--font-family--body)",
      "fontSize": "var(--wp--preset--font-size--medium, 1rem)"
    },
    "elements": {
      "link": {
        "color": { "text": "var(--wp--preset--color--green-600, #171717)" }
      }
    }
  }
}
